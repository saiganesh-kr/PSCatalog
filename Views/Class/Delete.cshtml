@model GSUClass
@{
    ViewData["Title"] = "Delete Class";
}

<h2>Delete Class</h2>
<p>Are you sure you want to delete this class?</p>

<h4>Class Details</h4>
<ul class="list-unstyled">
    <li><strong>Class Name:</strong> @Model.Name</li>
    <li><strong>Class Number:</strong> @Model.Number</li>
    <li><strong>Credits:</strong> @Model.Credit</li>
    <li><strong>Capacity:</strong> @Model.Capacity</li>
    <li><strong>Department:</strong> @Model.Department</li>
</ul>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="CourseId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
